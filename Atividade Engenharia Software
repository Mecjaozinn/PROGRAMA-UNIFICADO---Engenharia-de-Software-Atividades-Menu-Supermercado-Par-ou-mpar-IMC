def menu_principal():
    print("\n" + "=" * 42)
    print("   🐍  PROGRAMA UNIFICADO — PYTHON  🐍")
    print("   Engenharia de Software")
    print("=" * 42)

    while True:
        print("\n┌────────────────────────────────────┐")
        print("│         MENU PRINCIPAL              │")
        print("├────────────────────────────────────┤")
        print("│  1. 🛒  Menu Supermercado           │")
        print("│  2. 🎲  Par ou Ímpar                │")
        print("│  3. ⚖️   Calculadora de IMC          │")
        print("│  0. ❌  Sair                         │")
        print("└────────────────────────────────────┘")

        op = input("  Escolha uma opção: ").strip()

        if op == "1":
            menu_supermercado()
        elif op == "2":
            par_ou_impar()
        elif op == "3":
            calcular_imc()
        elif op == "0":
            print("\n  👋 Encerrando o programa. Até mais!\n")
            break
        else:
            print("  ❌ Opção inválida. Tente novamente.")


if __name__ == "__main__":
    menu_principal()
